---
import { BRAND } from '~/data/content';
---

<header class="pointer-events-none fixed inset-x-0 top-6 z-50 px-6">
  <nav
    class="pointer-events-auto mx-auto flex max-w-[var(--container-tight)] items-center justify-between rounded-pill bg-white px-6 py-4 lg:px-10"
    style="box-shadow: var(--shadow-nav);"
  >
    <a href="#" class="type-h3 tracking-tight text-ink">
      {BRAND.name}
    </a>

    <ul class="hidden gap-12 lg:flex">
      {BRAND.navLinks.map((link) => (
        <li>
          <a href={link.href} class="type-nav-link text-ink">
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-3">
      <button
        aria-label="Search"
        class="hidden h-12 w-12 items-center justify-center rounded-circle border border-ink/20 lg:inline-flex"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="7" />
          <line x1="21" y1="21" x2="16" y2="16" />
        </svg>
      </button>

      <button class="lg:hidden" aria-label="Open menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="4" y1="7" x2="20" y2="7" />
          <line x1="4" y1="12" x2="20" y2="12" />
          <line x1="4" y1="17" x2="20" y2="17" />
        </svg>
      </button>
    </div>
  </nav>
</header>

<div class="h-24" aria-hidden="true"></div>
