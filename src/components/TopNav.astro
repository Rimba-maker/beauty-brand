---
import { BRAND } from '~/data/content';
---

<header class="sticky top-0 z-50 w-full bg-canvas/95 backdrop-blur-sm">
  <nav class="mx-auto flex h-16 max-w-[var(--container-content)] items-center justify-between px-6">
    <a href="#" class="type-display-sm tracking-tight text-ink">
      {BRAND.name}
    </a>

    <ul class="hidden gap-8 md:flex">
      {BRAND.navLinks.map((link) => (
        <li>
          <a href={link.href} class="type-nav-link text-body hover:text-ink">
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-3">
      <button class="hidden type-button text-ink md:inline-block">Sign in</button>
      <button
        class="hidden h-11 rounded-md bg-primary px-5 type-button text-on-primary md:inline-block"
      >
        {BRAND.ctaPrimary}
      </button>
      <button class="md:hidden" aria-label="Open menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="4" y1="7" x2="20" y2="7" />
          <line x1="4" y1="12" x2="20" y2="12" />
          <line x1="4" y1="17" x2="20" y2="17" />
        </svg>
      </button>
    </div>
  </nav>
</header>
