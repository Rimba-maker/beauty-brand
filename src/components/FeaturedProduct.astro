---
import { FEATURED_PRODUCT } from '~/data/content';
---

<section class="px-6">
  <div class="mx-auto max-w-[1100px]">
    <article class="grid items-center gap-10 rounded-xl bg-brand-peach p-8 lg:grid-cols-2 lg:p-12">
      <div class="overflow-hidden rounded-lg bg-canvas/30">
        <img
          src={FEATURED_PRODUCT.imageUrl}
          alt={FEATURED_PRODUCT.name}
          width="800"
          height="800"
          loading="lazy"
          class="aspect-square w-full object-cover"
        />
      </div>

      <div class="text-ink">
        <p class="type-caption-uppercase">Hero this season</p>
        <h2 class="mt-3 type-display-md">{FEATURED_PRODUCT.name}</h2>
        <p class="mt-4 type-body-md">{FEATURED_PRODUCT.longDescription}</p>

        <ul class="mt-6 flex flex-wrap gap-2">
          {FEATURED_PRODUCT.ingredients.map((ing) => (
            <li class="rounded-pill bg-canvas px-3 py-1 type-caption text-ink">
              {ing}
            </li>
          ))}
        </ul>

        <div class="mt-8 flex items-center gap-6">
          <span class="type-display-sm">{FEATURED_PRODUCT.price}</span>
          <button class="h-11 rounded-md bg-canvas px-5 type-button text-ink">
            Add to bag
          </button>
        </div>
      </div>
    </article>
  </div>
</section>
