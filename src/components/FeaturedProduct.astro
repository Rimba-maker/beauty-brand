---
import { FEATURED_PRODUCT } from '~/data/content';
---

<section class="px-6 py-12">
  <div class="mx-auto max-w-[var(--container-content)]">
    <div
      class="relative overflow-hidden bg-ink"
      style="border-radius: var(--radius-stadium); box-shadow: var(--shadow-card);"
    >
      <div class="grid lg:grid-cols-2">
        <div class="relative">
          <img
            src={FEATURED_PRODUCT.imageUrl}
            alt={FEATURED_PRODUCT.name}
            width="900"
            height="900"
            loading="lazy"
            class="aspect-square w-full object-cover lg:aspect-auto lg:h-full"
          />
        </div>

        <div class="bg-ink p-6 text-canvas sm:p-8 lg:p-12 xl:p-16">
          <p class="eyebrow-dot type-eyebrow" style="color: var(--color-canvas);">
            Hero This Season
          </p>
          <h2 class="mt-6 type-h2" style="color: var(--color-canvas);">
            {FEATURED_PRODUCT.name}
          </h2>
          <p class="mt-6 type-body opacity-90">{FEATURED_PRODUCT.longDescription}</p>

          <ul class="mt-8 flex flex-wrap gap-2">
            {FEATURED_PRODUCT.ingredients.map((ing) => (
              <li
                class="inline-flex bg-white px-4 py-2 type-eyebrow text-ink"
                style="border-radius: var(--radius-pill);"
              >
                {ing}
              </li>
            ))}
          </ul>

          <div class="mt-8 flex flex-wrap items-center gap-4 lg:mt-12 lg:gap-6">
            <span class="type-h2" style="color: var(--color-canvas);">
              {FEATURED_PRODUCT.price}
            </span>
            <button
              class="rounded-button border-2 border-canvas bg-canvas px-6 py-3 type-button text-ink"
            >
              Add to bag
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
