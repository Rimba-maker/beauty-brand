---
import { BRAND } from '~/data/content';
---

<section class="relative px-6 py-12 lg:py-16">
  <div class="mx-auto max-w-[var(--container-content)]">
    <p class="eyebrow-dot type-eyebrow text-ink">A New Beauty Ritual</p>

    <h1 class="mt-6 type-h1 text-ink max-w-4xl">
      {BRAND.tagline}
    </h1>

    <p class="mt-8 max-w-xl type-body text-ink">
      {BRAND.subtagline}
    </p>

    <div class="mt-10 flex flex-wrap gap-3">
      <button
        class="rounded-button border-2 border-ink bg-ink px-6 py-3 type-button text-canvas"
        style="min-height: 44px;"
      >
        {BRAND.ctaPrimary}
      </button>
      <button
        class="rounded-button border-2 border-ink bg-white px-6 py-3 type-button text-ink"
        style="min-height: 44px;"
      >
        {BRAND.ctaSecondary}
      </button>
    </div>

    <div class="mt-16 overflow-hidden bg-ink" style="border-radius: var(--radius-stadium);">
      <img
        src={BRAND.heroImageUrl}
        alt="DEWY CO. ritual"
        width="1600"
        height="900"
        loading="eager"
        class="h-[50vh] w-full object-cover lg:h-[65vh]"
      />
    </div>
  </div>
</section>
