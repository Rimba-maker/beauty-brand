---
import { INGREDIENTS, type Ingredient } from '~/data/content';

type Variant = Ingredient['cardVariant'];

const cardBg: Record<Variant, string> = {
  lavender: 'bg-brand-lavender',
  peach: 'bg-brand-peach',
  ochre: 'bg-brand-ochre',
};
---

<section id="ingredients" class="px-6">
  <div class="mx-auto max-w-[var(--container-content)] py-section">
    <div class="mb-12 max-w-2xl">
      <p class="type-caption-uppercase text-muted">What's actually in there</p>
      <h2 class="mt-2 type-display-lg text-ink">Three actives doing the heavy lifting.</h2>
    </div>

    <ul class="grid gap-6 md:grid-cols-3">
      {INGREDIENTS.map((ing) => (
        <li class={`${cardBg[ing.cardVariant]} rounded-xl p-8 text-ink`}>
          <span class="text-5xl" aria-hidden="true">{ing.emoji}</span>
          <h3 class="mt-6 type-title-lg">{ing.name}</h3>
          <p class="mt-3 type-body-md">{ing.description}</p>
        </li>
      ))}
    </ul>
  </div>
</section>
