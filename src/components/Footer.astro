---
import { BRAND, FOOTER } from '~/data/content';
---

<footer class="bg-ink px-6 pb-32 pt-24 lg:px-12 text-white">
  <div class="mx-auto max-w-[var(--container-content)]">
    <h2 class="max-w-3xl type-h2" style="color: var(--color-canvas);">
      We're always here when you need us.
    </h2>

    <div class="mt-20 grid gap-12 md:grid-cols-12">
      <div class="md:col-span-4">
        <p class="type-h3" style="color: var(--color-canvas);">{BRAND.name}</p>
        <p class="mt-4 max-w-xs type-footer-link" style="color: var(--color-dust-taupe);">
          {BRAND.subtagline}
        </p>
      </div>

      <div class="grid gap-8 sm:grid-cols-2 md:col-span-8 md:grid-cols-4">
        {FOOTER.columns.map((col) => (
          <div>
            <p class="type-footer-header" style="color: var(--color-dust-taupe);">
              {col.heading}
            </p>
            <ul class="mt-5 space-y-3">
              {col.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="type-footer-link"
                    style="color: var(--color-canvas);"
                  >
                    {link.label} <span aria-hidden="true">↗</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <div
      class="mt-20 flex flex-wrap items-center justify-between gap-4 border-t pt-8"
      style="border-color: rgba(255,255,255,0.2);"
    >
      <p class="type-footer-link" style="color: var(--color-dust-taupe);">
        {FOOTER.tagline}
      </p>
      <div class="flex items-center gap-6">
        <a href="#" class="type-footer-link" style="color: var(--color-dust-taupe);">Privacy</a>
        <a href="#" class="type-footer-link" style="color: var(--color-dust-taupe);">Terms</a>
        <span
          class="inline-flex items-center gap-2 border px-4 py-2 type-footer-link"
          style="border-radius: var(--radius-pill); border-color: rgba(255,255,255,0.4); color: var(--color-canvas);"
        >
          🌐 ID — Indonesia
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="6 9 12 15 18 9" />
          </svg>
        </span>
      </div>
    </div>
  </div>
</footer>
