---
import { BRAND_STORY } from '~/data/content';
---

<section id="story" class="relative px-6 py-24 lg:py-32">
  <div class="relative mx-auto max-w-[var(--container-content)]">

    <!-- Ghost watermark: inside container, centered, two lines -->
    <span
      class="pointer-events-none absolute inset-0 flex select-none items-center justify-center text-center leading-none type-ghost"
      style="font-size: clamp(60px, 7.5vw, 120px); padding-inline: 24px;"
      aria-hidden="true"
    >
      Makeup should<br />love your skin back.
    </span>

    <div class="relative max-w-3xl">
      <p class="eyebrow-dot type-eyebrow text-ink">{BRAND_STORY.eyebrow}</p>
      <h2 class="mt-6 type-h2 text-ink">{BRAND_STORY.headline}</h2>

      <div class="mt-10 space-y-6">
        {BRAND_STORY.paragraphs.map((para) => (
          <p class="type-body text-ink">{para}</p>
        ))}
      </div>
    </div>
  </div>
</section>
