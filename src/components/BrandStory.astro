---
import { BRAND_STORY } from '~/data/content';
---

<section id="story" class="px-6">
  <div class="mx-auto max-w-[720px] py-section">
    <p class="type-caption-uppercase text-muted">{BRAND_STORY.eyebrow}</p>
    <h2 class="mt-3 type-display-lg text-ink">{BRAND_STORY.headline}</h2>

    <div class="mt-8 space-y-5">
      {BRAND_STORY.paragraphs.map((para) => (
        <p class="type-body-md text-body">{para}</p>
      ))}
    </div>
  </div>
</section>
