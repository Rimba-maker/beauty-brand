---
import { BRAND_STORY } from '~/data/content';
---

<section id="story" class="relative overflow-hidden px-6 py-24 lg:py-32">
  <div class="mx-auto max-w-[var(--container-content)]">
    <span
      class="pointer-events-none absolute -left-4 top-12 select-none type-ghost"
      style="font-size: clamp(96px, 14vw, 200px);"
      aria-hidden="true"
    >
      {BRAND_STORY.headline.split('.')[0]}.
    </span>

    <div class="relative max-w-3xl">
      <p class="eyebrow-dot type-eyebrow text-ink">{BRAND_STORY.eyebrow}</p>
      <h2 class="mt-6 type-h2 text-ink">{BRAND_STORY.headline}</h2>

      <div class="mt-10 space-y-6">
        {BRAND_STORY.paragraphs.map((para) => (
          <p class="type-body text-ink">{para}</p>
        ))}
      </div>
    </div>
  </div>
</section>
