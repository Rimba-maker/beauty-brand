---
import { PRODUCTS } from '~/data/content';
---

<section id="products" class="relative overflow-hidden px-6 py-24">
  <div class="mx-auto max-w-[var(--container-content)]">
    <p class="eyebrow-dot type-eyebrow text-ink">The Collection</p>
    <h2 class="mt-4 max-w-2xl type-h2 text-ink">
      Six hero products. Zero filler.
    </h2>
    <p class="mt-4 max-w-xl type-body text-slate">
      Every formula earns its place — built around skin-first actives at concentrations that actually do something.
    </p>
  </div>

  <div class="mt-12 -mx-6 overflow-x-auto pl-6 pb-6 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
    <ul class="flex gap-8 pr-12 snap-x snap-mandatory">
      {PRODUCTS.map((product) => (
        <li class="relative w-[320px] shrink-0 snap-start lg:w-[380px]">
          <div
            class="relative overflow-hidden bg-ink"
            style="border-radius: var(--radius-pill); aspect-ratio: 4/5;"
          >
            <img
              src={product.imageUrl}
              alt={product.name}
              width="380"
              height="475"
              loading="lazy"
              class="h-full w-full object-cover"
            />
            <span
              class="absolute left-6 top-6 inline-flex items-center bg-white px-4 py-2 type-eyebrow text-ink"
              style="border-radius: var(--radius-pill);"
            >
              · STORY
            </span>
            <button
              class="absolute bottom-6 right-6 inline-flex items-center bg-ink px-6 py-3 type-button text-canvas"
              style="border-radius: var(--radius-stadium);"
            >
              {product.price}
            </button>
          </div>

          <div class="mt-6 flex items-start justify-between gap-4">
            <div class="flex-1">
              <p class="eyebrow-dot type-eyebrow text-ink">Product</p>
              <h3 class="mt-3 type-h3 text-ink">{product.name}</h3>
              <p class="mt-2 type-body text-slate">{product.tagline}</p>
            </div>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
