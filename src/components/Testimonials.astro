---
import { TESTIMONIALS } from '~/data/content';

const eyebrows = ['Editor', 'Creator', 'Artist', 'Customer'];
---

<section id="testimonials" class="relative overflow-hidden px-6 py-24">
  <div class="mx-auto max-w-[var(--container-content)]">
    <p class="eyebrow-dot type-eyebrow text-ink">Word On The Street</p>
    <h2 class="mt-4 max-w-3xl type-h2 text-ink">
      From editors, makeup artists, and people who just like their skin.
    </h2>

    <ul class="mt-16 grid gap-x-6 gap-y-14 sm:grid-cols-2 lg:grid-cols-4">
      {TESTIMONIALS.map((t, i) => (
        <li class={`flex flex-col ${i % 2 === 1 ? 'lg:translate-y-12' : ''}`}>
          <div class="relative mx-auto">
            <div
              class="overflow-hidden bg-lifted"
              style="width: clamp(150px, 38vw, 220px); height: clamp(150px, 38vw, 220px); border-radius: var(--radius-circle);"
            >
              <img
                src={t.avatarUrl.replace('200', '400')}
                alt={t.name}
                width="220"
                height="220"
                loading="lazy"
                class="h-full w-full object-cover"
              />
            </div>
            <button
              aria-label={`Read more from ${t.name}`}
              class="absolute -bottom-2 -right-2 inline-flex items-center justify-center bg-white"
              style="border-radius: var(--radius-circle); box-shadow: var(--shadow-nav); width: 44px; height: 44px; min-width: 44px; min-height: 44px;"
            >
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="5" y1="12" x2="19" y2="12" />
                <polyline points="12 5 19 12 12 19" />
              </svg>
            </button>
          </div>

          <div class="mt-8 text-center">
            <p class="eyebrow-dot type-eyebrow text-ink">{eyebrows[i]}</p>
            <h3 class="mt-3 type-h3 text-ink">{t.name}</h3>
            <p class="mt-1 type-body text-slate">{t.role}</p>
            <p class="mt-4 type-body text-ink">"{t.quote}"</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
