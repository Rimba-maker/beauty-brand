---
import { EMAIL_CAPTURE } from '~/data/content';
---

<section class="px-6">
  <div class="mx-auto max-w-[var(--container-content)] pb-section">
    <div class="relative overflow-hidden rounded-xl bg-surface-soft p-12 lg:p-20">
      <div
        class="pointer-events-none absolute -right-20 -top-20 h-72 w-72 rounded-full opacity-50"
        style="background: radial-gradient(circle, var(--color-brand-lavender), transparent 70%);"
      ></div>
      <div
        class="pointer-events-none absolute -bottom-24 -left-16 h-80 w-80 rounded-full opacity-40"
        style="background: radial-gradient(circle, var(--color-brand-peach), transparent 70%);"
      ></div>

      <div class="relative max-w-2xl">
        <p class="type-caption-uppercase text-muted">{EMAIL_CAPTURE.eyebrow}</p>
        <h2 class="mt-3 type-display-md text-ink">{EMAIL_CAPTURE.headline}</h2>
        <p class="mt-4 type-body-md text-body">{EMAIL_CAPTURE.body}</p>

        <form class="mt-8 flex flex-col gap-3 sm:flex-row" onsubmit="return false;">
          <input
            type="email"
            placeholder={EMAIL_CAPTURE.placeholder}
            class="h-11 flex-1 rounded-md border border-hairline bg-canvas px-4 type-body-md text-ink"
          />
          <button
            type="submit"
            class="h-11 rounded-md bg-primary px-6 type-button text-on-primary"
          >
            {EMAIL_CAPTURE.cta}
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
