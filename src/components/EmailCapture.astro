---
import { EMAIL_CAPTURE } from '~/data/content';
---

<section class="px-6 py-12">
  <div class="mx-auto max-w-[var(--container-content)]">
    <div
      class="bg-lifted px-8 py-20 lg:px-20"
      style="border-radius: var(--radius-stadium);"
    >
      <div class="max-w-2xl">
        <p class="eyebrow-dot type-eyebrow text-ink">{EMAIL_CAPTURE.eyebrow}</p>
        <h2 class="mt-4 type-h2 text-ink">{EMAIL_CAPTURE.headline}</h2>
        <p class="mt-6 type-body text-slate">{EMAIL_CAPTURE.body}</p>

        <form class="mt-10 flex flex-col gap-3 sm:flex-row" onsubmit="return false;">
          <input
            type="email"
            placeholder={EMAIL_CAPTURE.placeholder}
            class="flex-1 border-2 border-ink/20 bg-white px-6 py-3 type-body text-ink"
            style="border-radius: var(--radius-pill);"
          />
          <button
            type="submit"
            class="rounded-button border-2 border-ink bg-ink px-8 py-3 type-button text-canvas"
          >
            {EMAIL_CAPTURE.cta}
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
