---
import '~/styles/global.css';
import TopNav from '~/components/TopNav.astro';
import Hero from '~/components/Hero.astro';
import ProductCarousel from '~/components/ProductCarousel.astro';
import FeaturedProduct from '~/components/FeaturedProduct.astro';
import BrandStory from '~/components/BrandStory.astro';
import Testimonials from '~/components/Testimonials.astro';
import IngredientSpotlight from '~/components/IngredientSpotlight.astro';
import EmailCapture from '~/components/EmailCapture.astro';
import Footer from '~/components/Footer.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>DEWY CO. — Dewy skin, made fun.</title>
    <meta
      name="description"
      content="Botanical-powered makeup that loves your skin back. Cruelty-free, vegan, made with intention."
    />
  </head>
  <body>
    <TopNav />
    <main>
      <Hero />
      <ProductCarousel />
      <FeaturedProduct />
      <BrandStory />
      <Testimonials />
      <IngredientSpotlight />
      <EmailCapture />
    </main>
    <Footer />
  </body>
</html>
